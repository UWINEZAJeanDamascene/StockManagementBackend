# =============================================================================
# Docker Ignore
# =============================================================================
# Files and directories to exclude from Docker build context
# =============================================================================

# Dependencies
node_modules/
node_modules/*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (will be mounted at runtime)
.env
.env.local
.env.development
.env.staging
.env.production
.env.*.local

# Build outputs
dist/
build/
coverage/
.next/
.nuxt/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Test files
test/
tests/
__tests__/
*.test.js
*.spec.js
jest.config.js
jest.setup.js

# Logs
logs/
*.log
logs/*

# Documentation
README.md
docs/
*.md

# Git
.git/
.gitignore
.gitattributes

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Docker (not needed in build)
docker/
docker-compose*.yml
Dockerfile
.dockerignore

# Misc
backups/
*.bak
*.tmp
temp/
tmp/

# Credentials (should be mounted, not built)
config/google-credentials.json
*.pem
*.key
*.crt

# Development files
.env.development.local
.env.test.local
.env.production.local

# Database
*.db
*.sqlite
*.sqlite3