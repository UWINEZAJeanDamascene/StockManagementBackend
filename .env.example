# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to .env.development, .env.staging, or .env.production
# and fill in the values for your environment.
# NEVER commit .env.development, .env.staging, or .env.production to git!
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Node environment: development, staging, production, test
NODE_ENV=development

# Server port
PORT=3000

# Frontend URL (for CORS and email links)
# Example: http://localhost:5173 (development), https://staging.yourdomain.com, https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# Allowed origins for CORS (comma-separated)
# Example: http://localhost:3000,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# MongoDB connection URI
# Local: mongodb://localhost:27017/stock-management
# Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
MONGODB_URI=mongodb+srv://stockM:stockM@stockm.e2ymnzi.mongodb.net/

# MongoDB connection pool settings (optional)
# MONGODB_MAX_POOL_SIZE=50
# MONGODB_MIN_POOL_SIZE=0
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=30000
# MONGODB_SOCKET_TIMEOUT_MS=0
# MONGODB_CONNECT_TIMEOUT_MS=30000
# MONGODB_HEARTBEAT_FREQUENCY_MS=10000

# =============================================================================
# JWT & AUTHENTICATION
# =============================================================================

# JWT secret key - MUST be changed in production!
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT token expiration
# Development: 60m (easier for testing)
# Staging/Production: 15m
JWT_EXPIRE=60m

# JWT refresh token expiration
JWT_REFRESH_EXPIRE=7d

# JWT issuer (optional)
# JWT_ISSUER=stock-management

# JWT audience (optional)
# JWT_AUDIENCE=stock-management-app

# =============================================================================
# PLATFORM ADMIN (one-time seed — see npm run seed:platform-admin)
# =============================================================================
# After setting these, run from Stock_tenancy_system folder:
#   npm run seed:platform-admin
# PLATFORM_ADMIN_EMAIL=admin@yourcompany.com
# PLATFORM_ADMIN_PASSWORD=min8charsSecurePassword
# PLATFORM_ADMIN_NAME=Platform Administrator

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================

# Session TTL in seconds (default: 86400 = 24 hours)
SESSION_TTL=86400

# Maximum concurrent sessions per user (FIFO eviction)
# Set to 0 for unlimited
SESSION_MAX_CONCURRENT=5

# =============================================================================
# SECURITY
# =============================================================================

# Bcrypt rounds for password hashing (higher = more secure but slower)
# Recommended: 10-12 for production
BCRYPT_ROUNDS=12

# Rate limiting window in milliseconds (default: 15 minutes)
# RATE_LIMIT_WINDOW_MS=900000

# Rate limiting max requests per window
# RATE_LIMIT_MAX_REQUESTS=100

# Low stock threshold for notifications
LOW_STOCK_THRESHOLD=10

# =============================================================================
# REDIS CONFIGURATION (Caching & Sessions)
# =============================================================================

# Option 1: Upstash Serverless Redis (recommended for serverless/production)
# UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# Option 2: Redis URL (Render, Redis Cloud, etc.)
# REDIS_URL=redis://username:password@host:port

# Option 3: Redis Cluster
# REDIS_CLUSTER_NODES=host1:6379,host2:6379,host3:6379

# Option 4: Standalone Redis (local/development)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your-password
# REDIS_DB=0

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Email provider: gmail, resend, or smtp
EMAIL_PROVIDER=gmail

# Gmail configuration
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASSWORD=your-16-char-app-password

# Resend configuration (uncomment and set EMAIL_PROVIDER=resend to use)
# RESEND_API_KEY=re_your_resend_api_key

# SMTP configuration (fallback)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password

# Email sender info
# EMAIL_FROM_ADDRESS=noreply@yourdomain.com
# EMAIL_FROM_NAME=StockManagement

# =============================================================================
# SMS CONFIGURATION (Optional)
# =============================================================================

# Twilio configuration
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1234567890

# Nexmo/Vonage configuration (alternative)
# NEXMO_API_KEY=your-nexmo-api-key
# NEXMO_API_SECRET=your-nexmo-api-secret
# NEXMO_FROM_NUMBER=StockMgmt

# =============================================================================
# NOTIFICATION SETTINGS
# =============================================================================

# Payment reminder days before due date
PAYMENT_REMINDER_DAYS=3

# Enable daily summary emails (true/false)
DAILY_SUMMARY_ENABLED=false

# Enable weekly summary emails (true/false)
WEEKLY_SUMMARY_ENABLED=true

# Large order threshold for notifications
LARGE_ORDER_THRESHOLD=10000

# =============================================================================
# CLOUD STORAGE (Optional)
# =============================================================================

# Dropbox configuration
# DROPBOX_ACCESS_TOKEN=your-dropbox-token

# Google Drive configuration
# GOOGLE_DRIVE_FOLDER_ID=your-folder-id
# GOOGLE_SERVICE_ACCOUNT_FILE=./config/google-credentials.json
# GOOGLE_DRIVE_OWNER_EMAIL=your-email@gmail.com

# =============================================================================
# AI/CHATBOT CONFIGURATION (Optional)
# =============================================================================
#
# Stacy AI supports a multi-provider fallback chain:
#   1. Groq (fastest hosted LLM) — recommended primary
#   2. Google Gemini (hosted fallback when Groq quota is hit)
#   3. Ollama (local/self-hosted — works when running locally or via a dedicated host)
#
# Configure ANY or ALL providers. If one fails or hits quota, the next is tried
# automatically with a 10-second timeout per provider.
#
# To use Ollama locally:
#   1. Install Ollama: https://ollama.com
#   2. Pull a model: ollama pull llama3.2
#   3. Set OLLAMA_BASE_URL=http://localhost:11434/v1
#   4. Restart the backend
#
# ═════════════════════════════════════════════════════════════════════════════
# CLOUD OLLAMA OPTIONS (choose one)
# ═════════════════════════════════════════════════════════════════════════════
#
# Ollama works in the cloud if you expose it via a public URL. Pick one:
#
# 1. VPS / Dedicated Server (Hetzner ~€5/mo, DigitalOcean ~$6/mo)
#    - Install: curl -fsSL https://ollama.com/install.sh | sh
#    - Pull:    ollama pull llama3.2
#    - Expose:  Use Caddy/nginx reverse proxy with basic auth or firewall rules
#    - Set:     OLLAMA_BASE_URL=https://your-vps-ip:11434/v1
#
# 2. Fly.io (GPU instances for fast inference)
#    - Deploy their Ollama template with `fly deploy`
#    - Set:     OLLAMA_BASE_URL=https://your-app.fly.dev/v1
#    - GPU machines available for larger models
#
# 3. Render (CPU only — slower, but simple)
#    - Deploy Ollama as a private service on the same Render account
#    - Set:     OLLAMA_BASE_URL=https://your-ollama-service.onrender.com/v1
#    - Note: CPU inference is slow. Use small models (llama3.2, phi4).
#
# 4. Cloudflare Tunnel / ngrok (free, temporary — for testing only)
#    - On your PC: cloudflared tunnel --url http://localhost:11434
#    - You get:    https://abc123.trycloudflare.com
#    - Set:        OLLAMA_BASE_URL=https://abc123.trycloudflare.com/v1
#    - Your PC must stay on. Good for testing, NOT production.
#
# Security: If exposing Ollama to the internet, always use a firewall or reverse
# proxy. Ollama has no built-in authentication. Never expose port 11434 directly.
# ═════════════════════════════════════════════════════════════════════════════
#
# Response caching reduces API calls. Default TTL is 30 seconds.
#
# =============================================================================

# --- Primary: Groq (fastest, recommended) ---
# Get your key at: https://console.groq.com/keys
# GROQ_API_KEY=your-groq-api-key
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Fallback 1: Google Gemini ---
# Get your key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash

# --- Fallback 2: Ollama (local / self-hosted) ---
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2

# --- Caching & performance tuning ---
# AI_CACHE_TTL_SECONDS=30
# AI_TIMEOUT_MS=10000

# =============================================================================
# LOGGING & MONITORING
# =============================================================================

# Log level: debug, info, warn, error
# Development: debug
# Staging: info
# Production: warn
LOG_LEVEL=debug

# Log database queries (true/false) - useful for debugging
LOG_QUERIES=false

# Sentry DSN for error tracking (optional)
# Example: https://xxxxx@sentry.io/xxxxx
# SENTRY_DSN=

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable email notifications (true/false)
ENABLE_EMAIL_NOTIFICATIONS=true

# Enable SMS notifications (true/false)
ENABLE_SMS_NOTIFICATIONS=false

# Enable cloud backup (true/false)
ENABLE_CLOUD_BACKUP=false

# Enable advanced reporting features (true/false)
ENABLE_ADVANCED_REPORTING=true

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================

# Backup storage location (local or cloud)
# BACKUP_STORAGE=local
# BACKUP_AWS_S3_BUCKET=your-bucket-name
# BACKUP_AWS_ACCESS_KEY_ID=
# BACKUP_AWS_SECRET_ACCESS_KEY=